<page-meta page-style="{{pageStyle}}" />
<scroll-view class="page settings theme-root {{themeClass}}" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="settings__body">
    <view class="settings__section">
      <view class="settings__section-title">账户</view>
      <view class="settings__card settings__card--list">
        <view class="settings__item" bind:tap="onGoProfile">
          <view class="settings__item-left">
            <t-icon name="user" size="40rpx" color="{{themeColors.primary}}" />
            <text>账户资料</text>
          </view>
          <t-icon name="chevron-right" size="36rpx" color="{{themeColors.textMuted}}" />
        </view>
        <view class="settings__item" bind:tap="onGoPassword">
          <view class="settings__item-left">
            <t-icon name="lock-on" size="40rpx" color="{{themeColors.primary}}" />
            <text>修改密码</text>
          </view>
          <t-icon name="chevron-right" size="36rpx" color="{{themeColors.textMuted}}" />
        </view>
      </view>
    </view>

    <view class="settings__section">
      <view class="settings__section-title">外观</view>
      <view class="settings__card">
        <theme-switch label="主题模式" />
        <view class="settings__hint">切换浅色或深色主题，立即生效并自动保存。</view>
      </view>
      <view class="settings__card settings__card--spaced">
        <color-theme-switch label="配色" />
        <view class="settings__hint">选择界面主色调配色方案。</view>
      </view>
    </view>

    <view class="settings__section">
      <view class="settings__card settings__card--list">
        <view class="settings__item settings__item--danger" bind:tap="onLogout">
          <view class="settings__item-left">
            <t-icon name="logout" size="40rpx" color="#e34d59" />
            <text>退出登录</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <t-message id="t-message" />
  <t-toast id="t-toast" />
</scroll-view>
