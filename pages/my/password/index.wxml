<page-meta page-style="{{pageStyle}}" />
<scroll-view class="page password theme-root {{themeClass}}" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="password__body">
    <view class="password__intro">
      <view class="password__title">修改登录密码</view>
      <view class="password__subtitle">新密码长度 8-128 位，修改后请使用新密码登录。</view>
    </view>

    <view class="password__form">
      <view class="password__field">
        <view class="password__label">当前密码</view>
        <t-input
          layout="vertical"
          borderless
          type="{{showOldPassword ? 'text' : 'password'}}"
          placeholder="请输入当前密码"
          value="{{oldPassword}}"
          status="{{fieldErrors.oldPassword ? 'error' : 'default'}}"
          tips="{{fieldErrors.oldPassword}}"
          t-class="password__form-input"
          bind:change="onOldPasswordInput"
        >
          <t-icon
            slot="suffix-icon"
            name="{{showOldPassword ? 'browse' : 'browse-off'}}"
            size="40rpx"
            color="{{themeColors.textMuted}}"
            catch:tap="onToggleOldPassword"
          />
        </t-input>
      </view>

      <view class="password__field">
        <view class="password__label">新密码</view>
        <t-input
          layout="vertical"
          borderless
          type="{{showNewPassword ? 'text' : 'password'}}"
          placeholder="请输入新密码（至少 8 位）"
          value="{{newPassword}}"
          status="{{fieldErrors.newPassword ? 'error' : 'default'}}"
          tips="{{fieldErrors.newPassword}}"
          t-class="password__form-input"
          bind:change="onNewPasswordInput"
        >
          <t-icon
            slot="suffix-icon"
            name="{{showNewPassword ? 'browse' : 'browse-off'}}"
            size="40rpx"
            color="{{themeColors.textMuted}}"
            catch:tap="onToggleNewPassword"
          />
        </t-input>
      </view>

      <view class="password__field">
        <view class="password__label">确认新密码</view>
        <t-input
          layout="vertical"
          borderless
          type="{{showConfirmPassword ? 'text' : 'password'}}"
          placeholder="请再次输入新密码"
          value="{{confirmPassword}}"
          status="{{fieldErrors.confirmPassword ? 'error' : 'default'}}"
          tips="{{fieldErrors.confirmPassword}}"
          t-class="password__form-input"
          bind:change="onConfirmPasswordInput"
        >
          <t-icon
            slot="suffix-icon"
            name="{{showConfirmPassword ? 'browse' : 'browse-off'}}"
            size="40rpx"
            color="{{themeColors.textMuted}}"
            catch:tap="onToggleConfirmPassword"
          />
        </t-input>
      </view>

      <button class="password__submit" disabled="{{submitting}}" bind:tap="onSubmit">
        <view class="btn-loading" wx:if="{{submitting}}">
          <t-loading theme="circular" size="40rpx" inherit-color />
        </view>
        <block wx:else>确认修改</block>
      </button>
    </view>
  </view>

  <t-message id="t-message" />
  <t-toast id="t-toast" />
</scroll-view>
