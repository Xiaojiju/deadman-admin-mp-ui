<page-meta page-style="{{pageStyle}}" />
<view class="page admin-page theme-root {{themeClass}}">
  <scroll-view class="admin-page__scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="admin-page__form">
      <view class="admin-page__field" wx:if="{{isEdit}}">
        <view class="admin-page__label">职位编码</view>
        <view class="admin-page__readonly">{{positionCode}}</view>
      </view>
      <view class="admin-page__field" wx:else>
        <view class="admin-page__label">职位编码</view>
        <t-input
          layout="vertical"
          borderless
          placeholder="如 ENGINEER"
          value="{{positionCode}}"
          status="{{fieldErrors.positionCode ? 'error' : 'default'}}"
          tips="{{fieldErrors.positionCode}}"
          t-class="admin-page__form-input"
          bind:change="onPositionCodeInput"
        />
      </view>

      <view class="admin-page__field">
        <view class="admin-page__label">职位名称</view>
        <t-input
          layout="vertical"
          borderless
          placeholder="请输入职位名称"
          value="{{positionName}}"
          status="{{fieldErrors.positionName ? 'error' : 'default'}}"
          tips="{{fieldErrors.positionName}}"
          t-class="admin-page__form-input"
          bind:change="onPositionNameInput"
        />
      </view>

      <view class="admin-page__field">
        <view class="admin-page__label">所属部门</view>
        <view class="admin-page__picker-trigger" bind:tap="onOpenDepartmentPicker">
          <t-input
            layout="vertical"
            borderless
            readonly
            value="{{departmentText}}"
            placeholder="请选择所属部门"
            suffix="›"
            t-class="admin-page__form-input"
          />
        </view>
      </view>

      <view class="admin-page__field" wx:if="{{isEdit}}">
        <view class="admin-page__label">状态</view>
        <view class="admin-page__picker-trigger" bind:tap="onOpenStatusPicker">
          <t-input
            layout="vertical"
            borderless
            readonly
            value="{{statusText}}"
            suffix="›"
            t-class="admin-page__form-input"
          />
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="admin-page__footer admin-page__footer--fixed">
    <button class="admin-page__btn admin-page__btn--primary" disabled="{{submitting}}" bind:tap="onSubmit">
      <view class="btn-loading" wx:if="{{submitting}}">
        <t-loading theme="circular" size="40rpx" inherit-color />
      </view>
      <block wx:else>保存</block>
    </button>
  </view>

  <t-picker
    visible="{{departmentVisible}}"
    value="{{departmentPickerValue}}"
    title="选择所属部门"
    bindconfirm="onDepartmentConfirm"
    bindcancel="onDepartmentCancel"
  >
    <t-picker-item options="{{departmentPickerOptions}}"></t-picker-item>
  </t-picker>

  <t-picker
    visible="{{statusVisible}}"
    value="{{statusPickerValue}}"
    title="选择状态"
    bindconfirm="onStatusConfirm"
    bindcancel="onStatusCancel"
  >
    <t-picker-item options="{{statusPickerOptions}}"></t-picker-item>
  </t-picker>

  <t-toast id="t-toast" />
</view>
