<page-meta page-style="{{pageStyle}}" />
<view class="page admin-page theme-root {{themeClass}}">
  <scroll-view class="admin-page__scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="admin-page__form">
      <view class="admin-page__field" wx:if="{{isEdit}}">
        <view class="admin-page__label">用户名</view>
        <view class="admin-page__readonly">{{username}}</view>
      </view>
      <view class="admin-page__field" wx:else>
        <view class="admin-page__label">用户名</view>
        <t-input
          layout="vertical"
          borderless
          placeholder="登录用户名"
          value="{{username}}"
          status="{{fieldErrors.username ? 'error' : 'default'}}"
          tips="{{fieldErrors.username}}"
          t-class="admin-page__form-input"
          bind:change="onUsernameInput"
        />
      </view>

      <view class="admin-page__field" wx:if="{{!isEdit}}">
        <view class="admin-page__label">初始密码</view>
        <t-input
          layout="vertical"
          borderless
          type="password"
          placeholder="至少 8 位"
          value="{{password}}"
          status="{{fieldErrors.password ? 'error' : 'default'}}"
          tips="{{fieldErrors.password}}"
          t-class="admin-page__form-input"
          bind:change="onPasswordInput"
        />
      </view>

      <view class="admin-page__field">
        <view class="admin-page__label">昵称</view>
        <t-input
          layout="vertical"
          borderless
          placeholder="显示名称"
          value="{{nickname}}"
          t-class="admin-page__form-input"
          bind:change="onNicknameInput"
        />
      </view>

      <view class="admin-page__field">
        <view class="admin-page__label">手机号</view>
        <t-input
          layout="vertical"
          borderless
          type="number"
          maxlength="11"
          placeholder="可选"
          value="{{phone}}"
          status="{{fieldErrors.phone ? 'error' : 'default'}}"
          tips="{{fieldErrors.phone}}"
          t-class="admin-page__form-input"
          bind:change="onPhoneInput"
        />
      </view>

      <view class="admin-page__field">
        <view class="admin-page__label">部门 / 职位</view>
        <view class="admin-page__picker-trigger" bind:tap="onOpenDeptPositionPicker">
          <t-input
            layout="vertical"
            borderless
            readonly
            value="{{deptPositionText}}"
            placeholder="请选择部门与职位"
            suffix="›"
            t-class="admin-page__form-input"
          />
        </view>
      </view>

      <view class="admin-page__field" wx:if="{{perms.assignRoles}}">
        <view class="admin-page__label">角色</view>
        <view class="admin-page__picker-trigger" bind:tap="onOpenRolePicker">
          <t-input
            layout="vertical"
            borderless
            readonly
            value="{{rolesText}}"
            suffix="›"
            t-class="admin-page__form-input"
          />
        </view>
      </view>

      <view class="admin-page__field" wx:if="{{isEdit}}">
        <view class="admin-page__label">状态</view>
        <view class="admin-page__picker-trigger" bind:tap="onOpenStatusPicker">
          <t-input
            layout="vertical"
            borderless
            readonly
            value="{{statusText}}"
            suffix="›"
            t-class="admin-page__form-input"
          />
        </view>
      </view>
    </view>

    <view class="admin-page__form" wx:if="{{isEdit && perms.resetPassword}}">
      <view class="admin-page__field">
        <view class="admin-page__label">重置密码</view>
        <view class="admin-page__picker-trigger" bind:tap="onToggleResetPanel">
          <t-input
            layout="vertical"
            borderless
            readonly
            value="{{showResetPanel ? '收起' : '设置新密码'}}"
            suffix="›"
            t-class="admin-page__form-input"
          />
        </view>
        <block wx:if="{{showResetPanel}}">
          <t-input
            layout="vertical"
            borderless
            type="password"
            placeholder="新密码至少 8 位"
            value="{{newPassword}}"
            status="{{fieldErrors.newPassword ? 'error' : 'default'}}"
            tips="{{fieldErrors.newPassword}}"
            t-class="admin-page__form-input admin-page__form-input--mt"
            bind:change="onNewPasswordInput"
          />
          <button
            class="admin-page__btn admin-page__btn--danger admin-page__btn--inline"
            disabled="{{resetting}}"
            bind:tap="onResetPassword"
          >
            <view class="btn-loading" wx:if="{{resetting}}">
              <t-loading theme="circular" size="40rpx" inherit-color />
            </view>
            <block wx:else>确认重置</block>
          </button>
        </block>
      </view>
    </view>
  </scroll-view>

  <view class="admin-page__footer admin-page__footer--fixed">
    <button class="admin-page__btn admin-page__btn--primary" disabled="{{submitting}}" bind:tap="onSubmit">
      <view class="btn-loading" wx:if="{{submitting}}">
        <t-loading theme="circular" size="40rpx" inherit-color />
      </view>
      <block wx:else>保存</block>
    </button>
  </view>

  <view
    class="user-form__picker-loading"
    wx:if="{{deptPositionVisible && positionPickerLoading}}"
    catchtouchmove="true"
  >
    <t-loading theme="circular" size="48rpx" inherit-color />
  </view>

  <t-picker
    visible="{{deptPositionVisible}}"
    value="{{deptPositionValue}}"
    title="选择部门与职位"
    bindconfirm="onDeptPositionConfirm"
    bindpick="onDeptPositionPick"
    bindcancel="onDeptPositionCancel"
  >
    <t-picker-item options="{{departmentPickerOptions}}"></t-picker-item>
    <t-picker-item options="{{positionPickerOptions}}"></t-picker-item>
  </t-picker>

  <t-picker
    visible="{{statusVisible}}"
    value="{{statusPickerValue}}"
    title="选择状态"
    bindconfirm="onStatusConfirm"
    bindcancel="onStatusCancel"
  >
    <t-picker-item options="{{statusPickerOptions}}"></t-picker-item>
  </t-picker>

  <t-toast id="t-toast" />
</view>
