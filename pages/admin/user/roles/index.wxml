<wxs module="_">
module.exports.contain = function(arr, key) {
  return arr.indexOf(key) > -1;
};
</wxs>

<page-meta page-style="{{pageStyle}}" />
<scroll-view class="page admin-page theme-root {{themeClass}}" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="admin-page__scroll">
    <view class="admin-page__section-title" wx:if="{{userName}}">用户：{{userName}}</view>

    <view class="admin-page__loading" wx:if="{{loading}}">
      <t-loading theme="circular" size="48rpx" inherit-color />
    </view>
    <view class="role-select" wx:else>
      <t-checkbox-group value="{{selectedRoleIds}}" bind:change="onRoleChange">
        <view
          wx:for="{{roleList}}"
          wx:key="id"
          class="role-select__card {{_.contain(selectedRoleIds, item.id) ? 'role-select__card--active' : ''}}"
        >
          <t-icon
            wx:if="{{_.contain(selectedRoleIds, item.id)}}"
            name="check"
            t-class="role-select__icon"
            ariaHidden="{{true}}"
          />
          <view class="role-select__body">
            <view class="role-select__head">
              <text class="role-select__name">{{item.roleName}}</text>
              <text class="role-select__status role-select__status--{{item.status === 1 ? 'on' : 'off'}}">{{item.statusText}}</text>
            </view>
            <text class="role-select__desc">{{item.description}}</text>
          </view>
          <t-checkbox value="{{item.id}}" icon="none" borderless t-class="role-select__checkbox" />
        </view>
      </t-checkbox-group>
    </view>

    <view class="admin-page__footer">
      <button
        class="admin-page__btn admin-page__btn--primary {{canSubmit ? '' : 'admin-page__btn--disabled'}}"
        disabled="{{!canSubmit || submitting}}"
        bind:tap="onSubmit"
      >
        <view class="btn-loading" wx:if="{{submitting}}">
          <t-loading theme="circular" size="40rpx" inherit-color />
        </view>
        <block wx:else>{{isPickMode ? '确定' : '保存'}}</block>
      </button>
    </view>
  </view>
  <t-toast id="t-toast" />
</scroll-view>
