<page-meta page-style="{{pageStyle}}" />
<view class="page admin-page theme-root {{themeClass}}">
  <scroll-view
    class="admin-page__scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="onScrollToLower"
    lower-threshold="120"
  >
    <view class="admin-page__search">
      <t-icon name="search" size="32rpx" color="{{themeColors.textMuted}}" />
      <input
        class="admin-page__search-input"
        placeholder="搜索用户名、昵称或手机号..."
        placeholder-class="admin-page__search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
      />
    </view>

    <view class="admin-page__loading" wx:if="{{loading}}">
      <t-loading theme="circular" size="48rpx" inherit-color />
    </view>
    <view class="admin-page__card" wx:elif="{{list.length}}">
      <t-swipe-cell
        wx:for="{{list}}"
        wx:key="id"
        class="admin-page__swipe-item"
        disabled="{{!perms.update && !perms.remove}}"
      >
        <view class="admin-page__item admin-page__item--flat">
          <view class="admin-page__item-row">
            <view class="admin-page__item-main">
              <view class="admin-page__item-head">
                <text class="admin-page__item-title admin-page__item-title--inline">{{item.displayName}}</text>
                <text class="admin-page__item-code">{{item.username}}</text>
              </view>
              <view class="admin-page__item-meta">「部门：{{item.departmentName}} 」· 「职位：{{item.positionsText}}」</view>
            </view>
            <view class="admin-page__item-aside">
              <view class="admin-page__tag {{item.status === 0 ? 'admin-page__tag--disabled' : ''}}">{{item.statusText}}</view>
              <text class="admin-page__item-meta-right">{{item.rolesText}}</text>
            </view>
          </view>
        </view>
        <view slot="right" class="admin-swipe__actions">
          <view
            wx:if="{{perms.update}}"
            class="admin-swipe__btn admin-swipe__btn--edit"
            catch:tap="onSwipeEdit"
            data-id="{{item.id}}"
          >
            编辑
          </view>
          <view
            wx:if="{{perms.remove}}"
            class="admin-swipe__btn admin-swipe__btn--delete"
            catch:tap="onSwipeDelete"
            data-id="{{item.id}}"
            data-name="{{item.displayName}}"
          >
            删除
          </view>
        </view>
      </t-swipe-cell>
    </view>
    <view class="admin-page__empty" wx:else>暂无用户数据</view>

    <view class="admin-page__load-more" wx:if="{{!loading && list.length && loadingMore}}">
      <t-loading theme="circular" size="36rpx" inherit-color />
    </view>
    <view class="admin-page__load-more" wx:elif="{{!loading && list.length && !hasMore}}">已加载全部</view>
  </scroll-view>

  <admin-fab visible="{{perms.create}}" bind:tap="onCreate" />
  <t-toast id="t-toast" />
</view>
