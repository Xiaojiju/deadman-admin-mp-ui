<page-meta page-style="{{pageStyle}}" />
<view class="page admin-page theme-root {{themeClass}}">
  <scroll-view class="admin-page__scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="admin-page__search">
      <t-icon name="search" size="32rpx" color="{{themeColors.textMuted}}" />
      <input
        class="admin-page__search-input"
        placeholder="搜索部门名称或编码..."
        placeholder-class="admin-page__search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
      />
    </view>

    <view class="admin-page__loading" wx:if="{{loading}}">
      <t-loading theme="circular" size="48rpx" inherit-color />
    </view>
    <view class="admin-page__card dept-tree" wx:elif="{{list.length}}">
      <view
        class="dept-tree__row"
        wx:for="{{list}}"
        wx:key="id"
        style="padding-left: {{24 + item.level * 40}}rpx"
      >
        <view
          class="dept-tree__toggle"
          wx:if="{{item.hasChildren && !keyword}}"
          catch:tap="onToggleExpand"
          data-id="{{item.id}}"
        >
          <t-icon
            name="{{item.expanded ? 'chevron-down' : 'chevron-right'}}"
            size="32rpx"
            color="{{themeColors.textMuted}}"
          />
        </view>
        <view class="dept-tree__toggle dept-tree__toggle--placeholder" wx:else></view>

        <t-swipe-cell class="dept-tree__swipe" disabled="{{!perms.update && !perms.remove}}">
          <view class="dept-tree__body">
            <view class="admin-page__item-row">
              <view class="admin-page__item-main">
                <view class="admin-page__item-head">
                  <text class="admin-page__item-title admin-page__item-title--inline">{{item.deptName}}</text>
                  <text class="admin-page__item-code">{{item.deptCode}}</text>
                </view>
              </view>
              <view class="admin-page__item-aside">
                <view class="admin-page__tag {{item.status === 0 ? 'admin-page__tag--disabled' : ''}}">{{item.statusText}}</view>
              </view>
            </view>
          </view>
          <view slot="right" class="admin-swipe__actions">
            <view
              wx:if="{{perms.update}}"
              class="admin-swipe__btn admin-swipe__btn--edit"
              catch:tap="onSwipeEdit"
              data-id="{{item.id}}"
            >
              编辑
            </view>
            <view
              wx:if="{{perms.remove}}"
              class="admin-swipe__btn admin-swipe__btn--delete"
              catch:tap="onSwipeDelete"
              data-id="{{item.id}}"
              data-name="{{item.deptName}}"
            >
              删除
            </view>
          </view>
        </t-swipe-cell>
      </view>
    </view>
    <view class="admin-page__empty" wx:else>暂无部门数据</view>
  </scroll-view>

  <admin-fab visible="{{perms.create}}" bind:tap="onCreate" />
  <t-toast id="t-toast" />
</view>
